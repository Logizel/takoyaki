# Discord
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_CLIENT_ID=your_discord_app_id
DISCORD_CHANNEL_ID=fallback_channel_id

# GitHub App (single app handles both OAuth and webhook events)
GITHUB_APP_NAME=TakoyakiBot
GITHUB_CLIENT_ID=your_github_app_client_id
GITHUB_CLIENT_SECRET=your_github_app_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_string

# Server
BASE_URL=https://takoyaki.onrender.com
# Set to your local path for development, /data/data.json on Render
DATA_PATH=./data/data.json
